# ── Copy this file to .env and fill in your values ──
# .env is gitignored — never commit real keys

# RapidAPI keys (twitter-api45 on rapidapi.com)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_KEY_BACKUP=your_backup_rapidapi_key_here
RAPIDAPI_HOST=twitter-api45.p.rapidapi.com
PORT=3001

# Turso Database (your own DB)
TURSO_URL=libsql://your-db-name.region.turso.io
TURSO_TOKEN=your_turso_auth_token_here

# Python API (Brand Visibility agent FastAPI backend) — the Node layer proxies
# /api/brand-visibility/config/* to this base URL. Default is the local dev port.
PYTHON_API_URL=http://localhost:8000

# --- Creator Radar agent (Fastify service, separate Railway) ---
# The Node layer proxies /api/creator-radar/* to this base URL.
# CREATOR_RADAR_INTERNAL_SECRET must match the value set on the
# creator-radar Railway service (used as X-Internal-Secret header).
CREATOR_RADAR_BACKEND_URL=http://localhost:3002
CREATOR_RADAR_INTERNAL_SECRET=change-this-to-the-shared-secret

# JWT — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Admin credentials — auto-created on startup
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStrongPassword123!

# OpenRouter API (get key from openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Friend's PostgreSQL DB — READ-ONLY keyword source (never written to)
# e.g. postgresql://user:password@host:5432/kiteai_brand_visibility?sslmode=require
POSTGRES_URL=postgresql://user:password@host:5432/kiteai_brand_visibility?sslmode=require

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
