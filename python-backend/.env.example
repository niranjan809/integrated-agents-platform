# Scraper backend selection
SCRAPER_PROVIDER=twitter241    # x_official | twitter241

# Official X API v2
X_BEARER_TOKEN=

# RapidAPI — twitter-api45 by alexanderxbx
RAPIDAPI_KEY=
RAPIDAPI_HOST=twitter-api45.p.rapidapi.com

# OpenRouter LLM gateway
OPENROUTER_API_KEY=
OPENROUTER_MODEL_CLASSIFIER=google/gemini-2.5-flash
OPENROUTER_MODEL_DRAFTER=anthropic/claude-sonnet-4.5

# Turso (shared DB with dashboard)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=
MAX_API_CALLS_PER_RUN=12

# Runtime
LOG_LEVEL=INFO
SCRAPE_SLEEP_SECONDS=5
ENVIRONMENT=dev
