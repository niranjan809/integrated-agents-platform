  <tr><td>track</td><td>TEXT</td><td>A (collab) or B (ads only)</td></tr>
  <tr><td>d2</td><td>REAL</td><td>Collab Intent score 0–100 (AI-rated)</td></tr>
  <tr><td>d3</td><td>REAL</td><td>AI Relevance score 0–100 (AI-rated)</td></tr>
