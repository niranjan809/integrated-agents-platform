  <tr><td>d5</td><td>REAL</td><td>Reach Quality score 0–95 (algorithmic)</td></tr>
  <tr><td>overall</td><td>REAL</td><td>Final composite score 0–100</td></tr>
  <tr><td>dm_open</td><td>INT 0/1</td><td>Whether DM signal was detected in bio</td></tr>
  <tr><td>has_email</td><td>INT 0/1</td><td>Whether an email was found in bio</td></tr>
  <tr><td>contact_email</td><td>TEXT</td><td>Extracted email address (if any)</td></tr>
  <tr><td>ai_model</td><td>TEXT</td><td>Which AI model scored this account</td></tr>
  <tr><td>ai_reason</td><td>TEXT</td><td>AI's reasoning note</td></tr>
  <tr><td>run_id</td><td>INT</td><td>Which agent run last updated this record</td></tr>
  <tr><td>first_seen</td><td>TEXT</td><td>When this account was first collected</td></tr>
  <tr><td>last_updated</td><td>TEXT</td><td>When this record was last refreshed</td></tr>
</table>

