  <tr><td>name</td><td>TEXT</td><td>Display name</td></tr>
  <tr><td>bio</td><td>TEXT</td><td>Full profile bio/description</td></tr>
  <tr><td>followers</td><td>INT</td><td>Follower count at time of last fetch</td></tr>
  <tr><td>following</td><td>INT</td><td>Following count</td></tr>
  <tr><td>tweets</td><td>INT</td><td>Total tweet count</td></tr>
  <tr><td>verified</td><td>INT 0/1</td><td>Blue verification status</td></tr>
