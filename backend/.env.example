# ── Copy this file to .env and fill in your values ──
# .env is gitignored — never commit real keys

RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=twitter-api45.p.rapidapi.com
PORT=3001

# Comma-separated list of allowed frontend origins (leave blank to allow all — dev only)
# Example: https://kiteai-agent.vercel.app,https://your-preview.vercel.app
ALLOWED_ORIGINS=
