# Brand Visibility Agent (Python / FastAPI) — environment template.
# Copy to .env and fill in the secrets:   cp .env.example .env
# .env is gitignored — never commit real keys.

# ── Turso (source of truth for both X and LinkedIn agents) ──────────────────
# Same values as the KiteAI dashboard's .env.local. Get them from the Turso
# dashboard (turso.tech) or a teammate.
TURSO_DATABASE_URL=libsql://your-db-name.region.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ── OpenRouter (LLM classification + drafting) ──────────────────────────────
# Key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL_CLASSIFIER=google/gemini-2.5-flash
OPENROUTER_MODEL_DRAFTER=anthropic/claude-3.5-sonnet

# ── X (Twitter) scraper — twitter241 on RapidAPI ────────────────────────────
SCRAPER_PROVIDER=twitter241
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=twitter241.p.rapidapi.com
# Optional — only if using the official X API provider path.
X_BEARER_TOKEN=

# ── LinkedIn scraper — Fresh LinkedIn Scraper API on RapidAPI ───────────────
LINKEDIN_RAPIDAPI_KEY=your_linkedin_rapidapi_key_here
LINKEDIN_RAPIDAPI_HOST=fresh-linkedin-scraper-api.p.rapidapi.com
LINKEDIN_MAX_API_CALLS_PER_RUN=5
LINKEDIN_SLEEP_PAGINATED=2
LINKEDIN_SLEEP_QUERY=3

# ── API budgets (cost guards) ───────────────────────────────────────────────
# X per-run scrape-call budget (orchestrator tick / run-now).
MAX_API_CALLS_PER_RUN=12
# X monthly scrape-call cap used by the run-now budget guard (api/routers/x.py).
# The code defaults to 5000 if unset; documented here explicitly.
X_MONTHLY_API_BUDGET=5000
# LinkedIn monthly API budget (api/routers/linkedin.py).
LINKEDIN_MONTHLY_BUDGET=50

# ── FastAPI / CORS ──────────────────────────────────────────────────────────
# Comma-separated origins allowed to hit the Python API (CORS allowlist).
# P0 lockdown: set an EXPLICIT list in production — do NOT leave "*". Local dev
# can use http://localhost:5173. Node already has its own ALLOWED_ORIGINS.
ALLOWED_ORIGINS=https://kite-frontend-production.up.railway.app,https://kite-node-production.up.railway.app

# ── Cron auth ───────────────────────────────────────────────────────────────
# Shared secret between GitHub Actions cron, the Node gateway, and the Python
# service. P0 lockdown: ALL write endpoints (POST/PUT/PATCH/DELETE across
# x / linkedin / config) now require an X-Cron-Secret header matching this, in
# addition to POST /api/x/run-now. GET reads stay public for now (P0.5 migrates
# the frontend's direct read calls through the Node gateway).
# Generate a random 32-char string:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the SAME value on GitHub as a repository secret named X_CRON_SECRET.
X_CRON_SECRET=change-me-to-a-random-32char-string

# ── Misc ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
USE_V2_LEXICON=true
