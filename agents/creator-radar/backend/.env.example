# --- Server ---
HOST=0.0.0.0
PORT=3001
DEBUG=

# --- Postgres (AWS RDS) — primary datastore ---
# DATABASE_URL=postgresql://user:pass@host:5432/creator_radar?sslmode=require
# DATABASE_SSL=true

# --- RapidAPI (Instagram scraper) ---
RAPIDAPI_KEY=
RAPIDAPI_HOST=instagram-scraper21.p.rapidapi.com
RAPIDAPI_BASE_URL=https://instagram-scraper21.p.rapidapi.com
RAPIDAPI_PROFILE_PATH=/api/v1/info

# --- OpenRouter (Gemini fallback) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions

# --- TikTok (optional) ---
TIKTOK_RAPIDAPI_KEY=
TIKTOK_RAPIDAPI_HOST=tiktok-scraper7.p.rapidapi.com
TIKTOK_RAPIDAPI_BASE=https://tiktok-scraper7.p.rapidapi.com
TIKTOK_API_BUDGET_MONTHLY=250

# --- Budget ---
API_BUDGET_MONTHLY=100

# --- Platform proxy auth (matches kite-node's outgoing header) ---
# Set to same value as kite-node's CREATOR_RADAR_INTERNAL_SECRET.
# When set, matching header lets kite-node's proxy calls bypass
# cookie auth and be attached as service user.
CREATOR_RADAR_INTERNAL_SECRET=

# --- CORS ---
# NOT YET WIRED — server.js hardcodes localhost:5173. Needs code
# change to honor this in Phase 1 or Phase 2.
ALLOWED_ORIGINS=http://localhost:5173,https://kite-frontend-production.up.railway.app
