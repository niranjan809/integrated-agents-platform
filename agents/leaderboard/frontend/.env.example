# Backend API URL
# Local development: http://localhost:8000
# Production: set to your deployed backend URL (e.g. https://your-app.onrender.com)
VITE_API_URL=http://localhost:8000

# Auto sign-in for the embedded admin console (must match backend/.env's
# APP_USERNAME/APP_PASSWORD) — lets the platform's admin panel open this
# agent's Manage section without prompting for credentials again.
VITE_ADMIN_USERNAME=your-username
VITE_ADMIN_PASSWORD=your-secure-password
