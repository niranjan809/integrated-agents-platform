# Frontend environment variables
# For local dev: copy to .env.local
# For Vercel: set in Vercel dashboard → Settings → Environment Variables

# Backend URL — set to your Render backend URL in production
# Example: https://kiteai-agent-backend.onrender.com
VITE_API_URL=http://localhost:3001

# Python API URL (Brand Visibility agent FastAPI backend) — used by pythonApi.js
# for READ-ONLY /api/x/* and /api/linkedin/* calls. Config edits go through the
# Node proxy (VITE_API_URL), not this. Set to the deployed Python API in prod.
VITE_PYTHON_API_URL=http://localhost:8000
