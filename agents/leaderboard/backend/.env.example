# ─── Database (Turso / libSQL) ───────────────────────────────────────────────
# Get these from https://turso.tech after creating a database
# Local dev: leave both blank to fall back to SQLite (leaderboard.db)
TURSO_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── AI / Normalization ───────────────────────────────────────────────────────
# OpenRouter key for Gemini 2.5 Flash (scope classification + normalization)
# Get from https://openrouter.ai — only used in normalizer.py, never in scraper.py
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret

# Login credentials — any logged-in user has full access including the admin section
APP_USERNAME=your-username
APP_PASSWORD=your-secure-password
